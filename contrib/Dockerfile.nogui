FROM debian:bookworm-slim@sha256:02274f94f52336abd6ab4a8471ea09966613910ebaeed622429dc7b4b780e804 AS builder

ARG MAKE_JOBS=1

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates \
    git \
    curl \
    pkg-config \
    libtool \
    autoconf \
    autotools-dev \
    automake \
    binutils \
    build-essential \
    bsdextrautils \
    python3 \
    libevent-dev \
    libboost-all-dev \
    libsqlite3-dev \
    libminiupnpc-dev \
    libnatpmp-dev \
    libssl-dev \
    libzmq3-dev \
    systemtap-sdt-dev \
    libqrencode-dev \
    libdb-dev \
    libdb++-dev \
 && rm -rf /var/lib/apt/lists/*

WORKDIR /src
COPY . /src
# The host workspace may already contain configure output; clean it before configuring in-container.
RUN if [ -f Makefile ]; then make distclean || true; fi \
 && (cd src/secp256k1 && if [ -f Makefile ]; then make distclean || true; fi) \
 && find src -type f \( -name '*.o' -o -name '*.a' -o -name '*.la' -o -name '*.lo' -o -name 'Makefile' \) -exec rm -f {} + \
 && find src -type d \( -name '.libs' -o -name '_libs' \) -exec rm -rf {} + \
 && rm -rf autom4te.cache config.cache config.log config.status build config.stamp \
 && ./autogen.sh \
 && mkdir -p build \
 && cd build \
 && ../configure --without-gui --disable-tests --disable-bench --enable-wallet --with-incompatible-bdb --without-miniupnpc --disable-dependency-tracking \
 && make -j"${MAKE_JOBS}" \
 && strip --strip-unneeded \
     ./src/equalishcoind \
     ./src/equalishcoin-cli \
     ./src/equalishcoin-tx \
     ./src/equalishcoin-wallet


FROM debian:bookworm-slim@sha256:02274f94f52336abd6ab4a8471ea09966613910ebaeed622429dc7b4b780e804

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates \
    gosu \
    bash \
    curl \
    libevent-dev \
    libboost-all-dev \
    libsqlite3-dev \
    libminiupnpc-dev \
    libnatpmp1 \
    libssl3 \
    libzmq5 \
    libdb-dev \
    libdb++-dev \
 && rm -rf /var/lib/apt/lists/*

RUN useradd -m -u 1000 -s /bin/bash equalishcoin

WORKDIR /opt/equalishcoin

COPY --from=builder --chmod=755 /src/build/src/equalishcoind /usr/local/bin/equalishcoind
COPY --from=builder --chmod=755 /src/build/src/equalishcoin-cli /usr/local/bin/equalishcoin-cli
COPY --from=builder --chmod=755 /src/build/src/equalishcoin-tx /usr/local/bin/equalishcoin-tx
COPY --from=builder --chmod=755 /src/build/src/equalishcoin-wallet /usr/local/bin/equalishcoin-wallet

COPY --chmod=755 contrib/docker-entrypoint.sh /usr/local/bin/docker-entrypoint.sh

ENTRYPOINT ["/usr/local/bin/docker-entrypoint.sh"]
CMD ["equalishcoind"]