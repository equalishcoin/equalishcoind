# Equalishcoind RPC credentials (used by both equalishcoind and NOMP)
COIND_RPC_USER=eqlsrpc
COIND_RPC_PASSWORD=change-this-very-strong-password

# Equalishcoind networking
COIND_P2P_PORT=19901
COIND_RPC_PORT=19902
COIND_RPC_BIND=0.0.0.0
COIND_RPC_ALLOW_IP=0.0.0.0/0
COIND_TXINDEX=1
COIND_PRUNE=0
COIND_MAXCONNECTIONS=64
COIND_EXTRA_ARGS=

# NOMP to coind/redis service discovery inside docker-compose network
COIND_HOST=equalishcoind
REDIS_HOST=redis
REDIS_PORT=6379

# Pool payout address (REQUIRED)
POOL_ADDRESS=REPLACE_WITH_YOUR_EQUALISHCOIN_ADDRESS
POOL_PUBLIC_HOST=localhost

# NOMP ports
NOMP_CLI_PORT=17117
NOMP_STRATUM_PORT_LOW=3333
NOMP_STRATUM_PORT_MED=5555
NOMP_STRATUM_PORT_HIGH=7777
NOMP_WEB_PORT=8080
NOMP_WEB_PORT_HOST=8080

# NOMP runtime flags
NOMP_WEBSITE_ENABLED=false
NOMP_VALIDATE_WORKER_USERNAME=false

BOOTSTRAP_BLOCKS=2000

